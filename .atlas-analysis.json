  "keyFeatures": [
    "AI-powered translation of Laravel language files using multiple LLM providers",
    "Context-aware translations that maintain consistency and terminology",
    "Smart detection and translation of only missing keys without full regeneration",
    "Interactive chat mode for translation refinement and quality control",
    "Comprehensive validation tools to ensure translation completeness",
    "Support for OpenAI, Anthropic (Claude), and Gemini models",
    "Preserves nested array structure with dot notation access",
    "Fast mode option for quicker translations"
  ],
  "publicApiSurface": [
    "php artisan translate",
    "php artisan translate:validate",
    "Mateffy\\AiTranslations\\Translator",
    "Mateffy\\AiTranslations\\TranslationFile",
    "Mateffy\\AiTranslations\\TranslationAgent",
    "config/ai-translations.php"
